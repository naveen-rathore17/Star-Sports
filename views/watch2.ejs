<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">

<title><%= title %></title>

<script src="https://cdn.tailwindcss.com"></script>

<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css"/>
<script src="https://cdn.jsdelivr.net/npm/hls.js@1"></script>
<script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>

<style>

:root{
--plyr-color-main:#ef4444;
}

.plyr{
border-radius:12px;
overflow:hidden;
}

</style>

</head>

<body class="bg-black text-white min-h-screen flex flex-col">

<!-- HEADER -->

<header class="w-full border-b border-gray-800">

<div class="max-w-6xl mx-auto flex items-center justify-between px-4 py-4">

<h1 class="text-2xl md:text-3xl font-bold">

<span class="text-yellow-400">Six</span>
<span class="text-white">Storm</span>

</h1>

<div class="flex items-center gap-2 bg-red-600 px-3 py-1 rounded-full text-sm font-semibold animate-pulse">

<span>🔴</span>
<span>LIVE</span>

</div>

</div>

</header>


<!-- PLAYER -->

<main class="flex-grow flex items-center justify-center">

<div class="w-full max-w-5xl px-3 mt-6 relative">

<!-- LIVE OVERLAY -->
<div class="absolute top-3 left-3 z-10 bg-red-600 px-3 py-1 rounded text-xs font-bold animate-pulse">
LIVE
</div>

<video
id="player"
class="w-full aspect-video"
playsinline
controls
></video>

<p class="text-center text-gray-400 text-sm mt-3">
Watch Live Cricket Streaming on SixStorm
</p>

</div>

</main>


<!-- FOOTER -->

<footer class="border-t border-gray-800 mt-10">

<div class="max-w-6xl mx-auto px-4 py-6 text-center text-gray-400 text-sm">

<p class="font-semibold">

<span class="text-yellow-400">Six</span>
<span class="text-white">Storm</span> Live

</p>

<p class="mt-2">
Fast • Smooth • Mobile Friendly Streaming
</p>

<p class="mt-2 text-xs text-gray-500">
© 2026 SixStorm Live
</p>

</div>

</footer>


<script>

const video = document.getElementById("player")
const videoSrc = "<%- streamUrl %>"

const player = new Plyr(video,{
controls:[
'play-large',
'play',
'progress',
'current-time',
'mute',
'volume',
'settings',
'fullscreen'
],
settings:['quality','speed'],
speed:{
selected:1,
options:[0.5,1,1.25,1.5,2]
}
})


if(Hls.isSupported()){

const hls = new Hls({
maxBufferLength:30
})

hls.loadSource(videoSrc)
hls.attachMedia(video)

hls.on(Hls.Events.MANIFEST_PARSED,function(event,data){

const levels = hls.levels
const quality = levels.map(l => l.height)

player.options.quality = {
default: quality[0],
options: quality,
forced:true,
onChange:(q)=>{
levels.forEach((level,i)=>{
if(level.height === q){
hls.currentLevel = i
}
})
}
}

video.play()

})


// AUTO RECONNECT

hls.on(Hls.Events.ERROR,function(event,data){

if(data.fatal){

switch(data.type){

case Hls.ErrorTypes.NETWORK_ERROR:
console.log("reconnecting stream...")
hls.startLoad()
break

case Hls.ErrorTypes.MEDIA_ERROR:
hls.recoverMediaError()
break

default:
hls.destroy()
break

}

}

})

}

else if(video.canPlayType("application/vnd.apple.mpegurl")){

video.src = videoSrc
video.play()

}


// MOBILE AUTO FULLSCREEN

video.addEventListener("play",()=>{

if(window.innerWidth < 768){

if(video.requestFullscreen){
video.requestFullscreen()
}

}

})


// BLOCK RIGHT CLICK

document.addEventListener("contextmenu",event=>{
event.preventDefault()
})


// BLOCK DEVTOOLS SHORTCUTS

document.onkeydown=function(e){

if(e.keyCode==123){
return false
}

if(e.ctrlKey && e.shiftKey && e.keyCode==73){
return false
}

}

</script>

</body>
</html>